---
interface Props {
  date: Date;
}
const { date } = Astro.props;
const iso = date.toISOString();
const label = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
  // Dates in frontmatter are calendar dates (UTC midnight); render them in UTC
  // so a viewer behind UTC doesn't see the previous day.
  timeZone: 'UTC',
});
---

<time datetime={iso}>{label}</time>
